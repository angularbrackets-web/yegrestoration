---
---

<div class="command-strip fixed bottom-0 left-0 right-0 z-[200] h-[10vh] min-h-[70px] hidden lg:flex items-center px-6 lg:px-12">
  <div class="w-full flex items-center justify-between">
    <!-- Location -->
    <div class="hidden md:flex items-center gap-2 text-yeg-text-secondary">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span class="text-xs font-medium tracking-wider uppercase">
        Edmonton &bull; Surrounding Areas
      </span>
    </div>

    <!-- Trust Signals -->
    <div class="flex items-center gap-6 lg:gap-10">
      <div class="hidden sm:flex trust-badge">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-yeg-amber"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.73 3.35a2 2 0 0 1 1.48-2.18H6.09a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"
          ></path>
        </svg>
        <span>Live Answer 24/7</span>
      </div>
      <div class="hidden lg:flex trust-badge">
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
        <span>Locally Owned</span>
      </div>
    </div>

    <!-- Spacer -->
    <div class="hidden lg:block"></div>
  </div>
</div>
