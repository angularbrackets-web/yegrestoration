---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb, SERVICE_LABELS, type Lead } from '../../../lib/db';
import { REPLY_TEMPLATES } from '../../../lib/reply-templates';

const { id } = Astro.params;
let lead: Lead | null = null;
let dbError: string | null = null;

try {
  const sql = getDb();
  const rows = (await sql`SELECT * FROM leads WHERE id = ${id}`) as Lead[];
  lead = rows[0] ?? null;

  if (lead?.status === 'new') {
    await sql`UPDATE leads SET status = 'read' WHERE id = ${id}`;
    lead.status = 'read';
  }
} catch (e) {
  dbError = 'Could not load lead.';
  console.error(e);
}

const success = Astro.url.searchParams.get('success') === '1';
const replyError = Astro.url.searchParams.get('error');

function statusClasses(status: Lead['status']) {
  if (status === 'replied') return 'bg-green-900/40 text-green-300 border-green-800';
  if (status === 'read') return 'bg-zinc-800 text-zinc-400 border-zinc-700';
  return 'bg-blue-900/40 text-blue-300 border-blue-800';
}

const serviceLabel = lead ? (SERVICE_LABELS[lead.service] ?? lead.service) : '';
---

<AdminLayout title={lead ? `${lead.name} — Lead` : 'Lead'}>
  <div class="mb-5">
    <a href="/admin" class="text-zinc-500 hover:text-zinc-300 text-sm transition-colors">← All Leads</a>
  </div>

  {dbError && (
    <div class="bg-red-900/30 border border-red-800 rounded-lg px-4 py-3 text-red-300 text-sm">{dbError}</div>
  )}
  {!lead && !dbError && (
    <div class="text-zinc-600 text-sm">Lead not found.</div>
  )}

  {lead && (
    <div class="space-y-5">
      <!-- Lead info card -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
        <div class="flex items-start justify-between mb-5">
          <h1 class="text-white text-xl font-bold">{lead.name}</h1>
          <span class={`inline-flex items-center px-2.5 py-1 rounded text-xs font-medium border ${statusClasses(lead.status)}`}>
            {lead.status}
          </span>
        </div>

        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Phone</dt>
            <dd class="text-white">
              <a href={`tel:${lead.phone}`} class="hover:text-amber-400 transition-colors">{lead.phone}</a>
            </dd>
          </div>
          <div>
            <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Email</dt>
            <dd class="text-white">
              {lead.email
                ? <a href={`mailto:${lead.email}`} class="hover:text-amber-400 transition-colors">{lead.email}</a>
                : <span class="text-zinc-600">Not provided</span>
              }
            </dd>
          </div>
          <div>
            <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Service</dt>
            <dd class="text-white">{serviceLabel}</dd>
          </div>
          <div>
            <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Submitted</dt>
            <dd class="text-white">
              {new Date(lead.created_at).toLocaleString('en-CA', { dateStyle: 'medium', timeStyle: 'short' })}
            </dd>
          </div>
          {lead.replied_at && (
            <div>
              <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Replied</dt>
              <dd class="text-green-400">
                {new Date(lead.replied_at).toLocaleString('en-CA', { dateStyle: 'medium', timeStyle: 'short' })}
              </dd>
            </div>
          )}
          {lead.message && (
            <div class="sm:col-span-2">
              <dt class="text-zinc-500 text-xs uppercase tracking-wide mb-1">Message</dt>
              <dd class="text-white whitespace-pre-wrap bg-zinc-800/50 rounded-lg p-3 text-sm leading-relaxed">{lead.message}</dd>
            </div>
          )}
        </dl>
      </div>

      <!-- Reply section -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
        <h2 class="text-white font-semibold mb-4">Send Reply</h2>

        {!lead.email ? (
          <p class="text-zinc-500 text-sm">
            No email provided — contact by phone: <a href={`tel:${lead.phone}`} class="text-white hover:text-amber-400 transition-colors">{lead.phone}</a>
          </p>
        ) : (
          <>
            {success && (
              <div class="bg-green-900/30 border border-green-800 rounded-lg px-4 py-3 text-green-300 text-sm mb-4">
                Reply sent to {lead.email}.
              </div>
            )}
            {replyError && (
              <div class="bg-red-900/30 border border-red-800 rounded-lg px-4 py-3 text-red-300 text-sm mb-4">
                Failed to send reply. Please try again.
              </div>
            )}

            <div class="mb-4">
              <label class="block text-zinc-400 text-xs uppercase tracking-wide mb-1.5" for="template">
                Template
              </label>
              <select
                id="template-select"
                class="w-full bg-zinc-800 text-white border border-zinc-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-amber-500 transition-colors"
              >
                <option value="">— Select a template —</option>
                {REPLY_TEMPLATES.map(t => (
                  <option value={t.id}>{t.name}</option>
                ))}
                <option value="_custom">Custom message</option>
              </select>
            </div>

            <form method="POST" action="/api/admin/reply" class="space-y-4">
              <input type="hidden" name="leadId" value={lead.id} />
              <div>
                <label class="block text-zinc-400 text-xs uppercase tracking-wide mb-1.5" for="subject">
                  Subject
                </label>
                <input
                  type="text"
                  id="reply-subject"
                  name="subject"
                  required
                  class="w-full bg-zinc-800 text-white border border-zinc-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-amber-500 transition-colors"
                />
              </div>
              <div>
                <label class="block text-zinc-400 text-xs uppercase tracking-wide mb-1.5" for="body">
                  Message
                </label>
                <textarea
                  id="reply-body"
                  name="body"
                  rows="12"
                  required
                  class="w-full bg-zinc-800 text-white border border-zinc-700 rounded-lg px-4 py-2.5 text-sm font-mono focus:outline-none focus:border-amber-500 transition-colors resize-y"
                ></textarea>
              </div>
              <div class="flex items-center gap-3">
                <button
                  type="submit"
                  class="bg-amber-500 hover:bg-amber-400 text-black font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors"
                >
                  Send Reply
                </button>
                <span class="text-zinc-600 text-xs">Sending to {lead.email}</span>
              </div>
            </form>
          </>
        )}
      </div>
    </div>
  )}
</AdminLayout>

<script define:vars={{ templates: REPLY_TEMPLATES, leadName: lead?.name ?? '', leadService: serviceLabel }}>
  const sel = document.getElementById('template-select');
  const subj = document.getElementById('reply-subject');
  const body = document.getElementById('reply-body');

  function fill(str) {
    return str
      .replace(/\{\{name\}\}/g, leadName)
      .replace(/\{\{service\}\}/g, leadService);
  }

  sel?.addEventListener('change', () => {
    const id = sel.value;
    if (!id || id === '_custom') return;
    const tpl = templates.find(t => t.id === id);
    if (!tpl) return;
    subj.value = fill(tpl.subject);
    body.value = fill(tpl.body);
  });
</script>
