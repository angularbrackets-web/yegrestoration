---
export const prerender = false;
import '../../styles/global.css';

const error = Astro.url.searchParams.has('error');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — YEG Restoration</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="bg-zinc-950 min-h-screen flex items-center justify-center antialiased">
    <div class="w-full max-w-sm px-4">
      <div class="text-center mb-8">
        <p class="text-zinc-500 text-xs uppercase tracking-widest mb-1">YEG Restoration</p>
        <h1 class="text-white text-2xl font-bold">Admin Login</h1>
      </div>

      {error && (
        <div class="bg-red-900/30 border border-red-800 rounded-lg px-4 py-3 text-red-300 text-sm text-center mb-4">
          Invalid password. Try again.
        </div>
      )}

      <form
        method="POST"
        action="/api/admin/login"
        class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 space-y-4"
      >
        <div>
          <label class="block text-zinc-400 text-sm mb-1.5" for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            autofocus
            required
            class="w-full bg-zinc-800 text-white border border-zinc-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-amber-500 transition-colors"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2.5 rounded-lg text-sm transition-colors"
        >
          Sign In
        </button>
      </form>
    </div>
  </body>
</html>
