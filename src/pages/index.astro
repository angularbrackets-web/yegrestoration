---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.svelte';
import CommandStrip from '../components/CommandStrip.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../sections/HeroSection.astro';
import VideoReel from '../components/VideoReel.svelte';
import StatsBar from '../components/StatsBar.astro';
import ServiceSection from '../sections/ServiceSection.astro';
import AdditionalServices from '../sections/AdditionalServices.astro';
import ProcessSection from '../sections/ProcessSection.astro';
import TestimonialsSection from '../sections/TestimonialsSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import RecentPostsSection from '../sections/RecentPostsSection.astro';
import LocationsSection from '../sections/LocationsSection.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import { primaryServices } from '../data/services';
import { heroSliderImages } from '../lib/hero-images';

// LCP preloads: the hero comparison slider. Media queries mirror the lg:
// (1024px) breakpoint that decides which slider instance renders.
const { desktopBefore, desktopAfter, mobileBefore, mobileAfter } = heroSliderImages;
const heroPreloads = [
  { href: mobileBefore.src, media: '(max-width: 1023.98px)' },
  { href: mobileAfter.src, media: '(max-width: 1023.98px)' },
  { href: desktopBefore.src, media: '(min-width: 1024px)' },
  { href: desktopAfter.src, media: '(min-width: 1024px)' },
];
---

<Layout preloadImages={heroPreloads}>
  <!-- Texture overlays -->
  <div class="grain-overlay"></div>
  <div class="concrete-texture"></div>

  <!-- Navbar island (hydrates immediately for scroll detection) -->
  <Navbar client:load />

  <!-- Main content -->
  <main id="main-content" class="relative">
    <HeroSection />
    <VideoReel client:visible />
    <StatsBar />
    {
      primaryServices.map((s, i) => (
        <ServiceSection
          id={s.id}
          bgWord={s.bgWord}
          tagline={s.cardTagline}
          title={s.shortName}
          description={s.cardDescription}
          features={s.features}
          ctaText="Get Free Assessment"
          image={s.image!}
          imageAlt={s.imageAlt}
          href={s.page ? `/${s.page.slug}/` : undefined}
          reversed={i % 2 !== 0}
        />
      ))
    }
    <AdditionalServices />
    <ProcessSection />
    <TestimonialsSection />
    <RecentPostsSection />
    <LocationsSection />
    <ContactSection />
  </main>

  <Footer />
  <CommandStrip />
  <MobileCallBar formAnchor="#contact" />
</Layout>
