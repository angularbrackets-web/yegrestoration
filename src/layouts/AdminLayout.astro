---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — YEG Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="bg-zinc-950 min-h-screen text-zinc-300 antialiased">
    <nav class="border-b border-zinc-800 bg-zinc-900/80 backdrop-blur sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/admin" class="text-white font-semibold text-sm tracking-wide">YEG Restoration — Admin</a>
        <form method="POST" action="/api/admin/logout">
          <button
            type="submit"
            class="text-zinc-500 hover:text-zinc-200 text-sm transition-colors"
          >
            Sign out
          </button>
        </form>
      </div>
    </nav>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>
  </body>
</html>
