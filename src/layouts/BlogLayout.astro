---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.astro';
import { blogArticleSchema } from '../lib/seo';
import { getReadingTime } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  slug: string;
  heroImage?: string;
  heroImageAlt?: string;
  rawContent?: string;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author,
  tags,
  slug,
  heroImage,
  heroImageAlt,
  rawContent = '',
} = Astro.props;

const readingTime = getReadingTime(rawContent);
const schema = blogArticleSchema({ title, description, publishDate, updatedDate, slug, heroImage });

const formattedDate = publishDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} | YEG Restoration`} description={description} ogImage={heroImage}>
  <!-- Texture overlays -->
  <div class="grain-overlay"></div>
  <div class="concrete-texture"></div>

  <Navbar client:load />

  <!-- Blog Posting JSON-LD (valid anywhere in document per Google guidelines) -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <main id="main-content" class="relative">
    <article class="pt-28 pb-24 px-6">
      <div class="max-w-2xl mx-auto">

        <!-- Article Header -->
        <header class="mb-10">
          <!-- Tags -->
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              {tags.map(tag => (
                <span class="text-xs font-medium text-yeg-amber/70 uppercase tracking-widest border border-yeg-amber/20 rounded-full px-3 py-1">
                  {tag.replace(/-/g, ' ')}
                </span>
              ))}
            </div>
          )}

          <!-- Title -->
          <h1 class="font-display font-bold text-yeg-text leading-tight mb-6"
            style="font-size: clamp(1.75rem, 4vw, 2.75rem); letter-spacing: -0.03em;">
            {title}
          </h1>

          <!-- Meta row -->
          <div class="flex flex-wrap items-center gap-4 text-sm text-yeg-text-secondary border-b border-black/[0.07] pb-6">
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="text-yeg-amber/50" aria-hidden="true">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                <line x1="16" x2="16" y1="2" y2="6"></line>
                <line x1="8" x2="8" y1="2" y2="6"></line>
                <line x1="3" x2="21" y1="10" y2="10"></line>
              </svg>
              <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            </span>
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="text-yeg-amber/50" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              {readingTime} min read
            </span>
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="text-yeg-amber/50" aria-hidden="true">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              {author}
            </span>
          </div>
        </header>

        <!-- Hero Image -->
        {heroImage && (
          <div class="image-frame rounded-xl overflow-hidden mb-10">
            <img src={heroImage} alt={heroImageAlt ?? title} class="w-full aspect-video object-cover" loading="eager" />
          </div>
        )}

        <!-- Article Body -->
        <div class="blog-prose">
          <slot />
        </div>

        <!-- CTA Block -->
        <div class="mt-14 p-7 rounded-2xl border border-yeg-amber/20 bg-yeg-amber/[0.04]">
          <p class="font-display font-bold text-yeg-text text-lg mb-2">
            Need emergency help right now?
          </p>
          <p class="text-yeg-text-secondary text-sm mb-5">
            YEG Restoration responds 24/7 across Edmonton. A specialist answers every call.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="tel:7804793285" class="cta-primary text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.73 3.35a2 2 0 0 1 1.48-2.18H6.09a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"></path>
              </svg>
              (780) 479-3285
            </a>
            <a href="/#contact" class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-black/15 text-yeg-text-secondary hover:text-yeg-text hover:border-black/25 transition-all duration-200 text-sm font-medium">
              Request a callback
            </a>
          </div>
        </div>

        <!-- Back to blog -->
        <div class="mt-10">
          <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-yeg-text-secondary hover:text-yeg-amber transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m12 19-7-7 7-7"></path>
              <path d="M19 12H5"></path>
            </svg>
            Back to all articles
          </a>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
