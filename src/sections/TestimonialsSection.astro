---
// Commitments section (formerly testimonials). Real customer reviews were not
// yet available at launch — no fabricated quotes or ratings. When the Google
// Business Profile has real reviews, re-introduce them here (and re-add
// aggregateRating in src/lib/seo.ts with real values).
const commitments = [
  {
    title: 'A specialist answers. Always.',
    copy: 'Call at 2 a.m. on a Sunday and a restoration specialist picks up — no call centre, no voicemail, no hold music. Your crew is dispatched while you’re still on the phone.',
    kicker: 'Live answer, 24/7',
  },
  {
    title: 'One crew, start to finish.',
    copy: 'The team that shows up for the emergency stays through the rebuild. And we bill your insurance company directly, so you’re not fronting the cost of a covered claim.',
    kicker: 'Direct insurance billing',
  },
  {
    title: 'A written scope before work starts.',
    copy: 'Free on-site assessment, a written scope of work, and a written guarantee on every job. You know exactly what happens — and what it costs — before we lift a tool.',
    kicker: 'Free assessment, guaranteed work',
  },
];
---

<section
  id="testimonials"
  class="bg-yeg-bg-light py-20 lg:py-28"
  style="border-top: 1px solid rgba(0,0,0,0.06); border-bottom: 1px solid rgba(0,0,0,0.06);"
>
  <div class="px-6 lg:px-[8vw]">
    <!-- Header -->
    <div
      data-testimonials-header
      class="flex flex-col lg:flex-row lg:items-end justify-between mb-12 lg:mb-16 gap-6"
    >
      <div>
        <p class="text-xs font-medium text-yeg-amber-deep uppercase tracking-widest mb-3">
          Why Edmonton Calls Us
        </p>
        <h2 class="font-display font-extrabold text-display-lg text-yeg-text mb-3">
          Our Commitments to You
        </h2>
        <p class="text-yeg-text-secondary text-lg">
          Not promises on a poster — how every job runs, in writing.
        </p>
      </div>

      <!-- TODO: when the Google Business Profile is live with real reviews, add the
           reviews link + rating badge back here:
      <a href="GBP_REVIEWS_URL" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 text-sm text-yeg-amber-deep hover:text-yeg-amber-deep-hover transition-colors">
        <span class="font-semibold">Read our Google reviews</span>
        <span>&rarr;</span>
      </a>
      -->
    </div>

    <!-- Commitment cards -->
    <div data-testimonials-cards class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {
        commitments.map((c) => (
          <div
            class="testimonial-card rounded-xl p-px"
            style="background: linear-gradient(135deg, rgba(242,201,76,0.25) 0%, rgba(242,201,76,0.10) 40%, rgba(0,0,0,0.03) 100%);"
          >
            <div class="bg-yeg-bg rounded-[11px] p-6 lg:p-8 flex flex-col h-full">
              <!-- Kicker -->
              <div class="flex items-center gap-2 mb-5">
                <span class="w-1.5 h-1.5 rounded-full bg-yeg-amber flex-shrink-0" />
                <span class="text-[11px] font-semibold uppercase tracking-wider text-yeg-amber-deep">
                  {c.kicker}
                </span>
              </div>

              <!-- Commitment -->
              <h3 class="font-display font-bold text-xl text-yeg-text mb-3">{c.title}</h3>
              <p class="text-yeg-text-secondary text-sm lg:text-base leading-relaxed flex-1 font-light">
                {c.copy}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('#testimonials');
  if (section) {
    const header = section.querySelector('[data-testimonials-header]');
    const cardsContainer = section.querySelector('[data-testimonials-cards]');
    const cards = section.querySelectorAll('.testimonial-card');

    if (header) {
      gsap.set(header, { y: 24, opacity: 0 });
      gsap.to(header, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: { trigger: section, start: 'top 80%', once: true },
      });
    }

    if (cards.length) {
      gsap.set(cards, { y: 36, opacity: 0 });
      gsap.to(cards, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power2.out',
        scrollTrigger: { trigger: cardsContainer, start: 'top 85%', once: true },
      });
    }
  }
</script>
