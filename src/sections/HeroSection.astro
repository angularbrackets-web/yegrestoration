---
import ComparisonSlider from '../components/ComparisonSlider.svelte';
---

<section
  data-hero-section
  class="relative min-h-screen overflow-hidden bg-yeg-bg flex flex-col lg:flex-row lg:items-center z-10"
>
  <!-- Background Word -->
  <div
    data-hero-bgword
    class="absolute bg-word opacity-0"
    style="left: 4vw; top: 8vh;"
  >
    EMERGENCY
  </div>

  <!-- Ambient amber glow -->
  <div
    class="absolute inset-0 pointer-events-none z-10"
    style="background: radial-gradient(ellipse 55% 45% at 10% 20%, rgba(242,201,76,0.05) 0%, transparent 65%);"
  >
  </div>

  <!-- Left Content Gradient -->
  <div
    class="absolute left-0 top-0 bottom-0 w-full lg:w-[45%] z-10"
    style="background: linear-gradient(to right, #F8F6F3 0%, #F8F6F3 60%, transparent 100%);"
  >
  </div>

  <!-- Text Content -->
  <div class="relative z-20 w-full lg:w-[40%] px-6 lg:px-[8vw] pt-24 lg:pt-0 pb-24 lg:pb-0">
    <!-- Headline -->
    <h1
      data-hero-headline
      class="font-display font-extrabold text-display-xl text-yeg-text uppercase mb-6"
    >
      <span class="word inline-block">YOUR</span>{' '}
      <span class="word inline-block">EMERGENCY</span>
      <br />
      <span class="word inline-block">ENDS</span>{' '}
      <span class="word inline-block text-yeg-amber">NOW</span>
    </h1>

    <!-- Subheadline -->
    <p
      data-hero-subhead
      class="text-yeg-text-secondary text-lg lg:text-xl leading-relaxed max-w-md mb-8 opacity-0"
    >
      4,200+ Edmonton families restored. 60-minute response, any time of day.
    </p>

    <!-- Primary CTA -->
    <div data-hero-cta class="flex items-start gap-4 mb-5 opacity-0">
      <a href="tel:7804793285" class="cta-primary animate-beacon-pulse">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.73 3.35a2 2 0 0 1 1.48-2.18H6.09a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"
          ></path>
        </svg>
        <span class="font-bold">Call (780) 479-3285</span>
      </a>
    </div>

    <!-- Trust Badges -->
    <div data-hero-trust class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-6 opacity-0">
      {
        ['IICRC Certified', '60-Min Response', 'Written Guarantee'].map((badge) => (
          <span class="trust-badge">
            <span class="w-1 h-1 rounded-full bg-yeg-amber/50 flex-shrink-0 inline-block" />
            {badge}
          </span>
        ))
      }
    </div>

    <!-- Mobile Slider -->
    <div class="lg:hidden mt-6 w-full aspect-[4/3] max-h-[45vh]">
      <ComparisonSlider
        client:load
        beforeImage="/before-damage.png"
        afterImage="/after-restored.png"
        beforeAlt="Before: Mold damage and deteriorated framing"
        afterAlt="After: Clean restored framing with new insulation"
      />
    </div>
  </div>

  <!-- Desktop Slider -->
  <div
    data-hero-slider
    class="hidden lg:block absolute right-0 top-[12vh] w-[60vw] h-[70vh] opacity-0"
  >
    <ComparisonSlider
      client:load
      beforeImage="/before-damage.png"
      afterImage="/after-restored.png"
      beforeAlt="Before: Mold damage and deteriorated framing with debris"
      afterAlt="After: Clean restored framing with new insulation and copper pipes"
    />
  </div>
</section>

<script>
  import gsap from 'gsap';

  const section = document.querySelector('[data-hero-section]') as HTMLElement;
  if (section) {
    const bgWord = section.querySelector('[data-hero-bgword]');
    const slider = section.querySelector('[data-hero-slider]');
    const headline = section.querySelector('[data-hero-headline]');
    const subhead = section.querySelector('[data-hero-subhead]');
    const cta = section.querySelector('[data-hero-cta]');
    const trust = section.querySelector('[data-hero-trust]');
    const words = headline?.querySelectorAll('.word');

    let xTo: ((v: number) => void) | null = null;
    let yTo: ((v: number) => void) | null = null;
    let parallaxEnabled = false;

    const loadTl = gsap.timeline({
      defaults: { ease: 'power2.out' },
      onComplete: () => {
        if (!slider) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        xTo = gsap.quickTo(slider, 'x', { duration: 0.6, ease: 'power2.out' });
        yTo = gsap.quickTo(slider, 'y', { duration: 0.8, ease: 'power2.out' });
        parallaxEnabled = true;
      },
    });

    if (bgWord) loadTl.fromTo(bgWord, { opacity: 0 }, { opacity: 1, duration: 0.6 }, 0);
    if (slider) loadTl.fromTo(slider, { x: '12vw', opacity: 0 }, { x: 0, opacity: 1, duration: 0.9 }, 0.1);
    if (words?.length) {
      loadTl.fromTo(words, { y: 40, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, stagger: 0.04 }, 0.2);
    }
    if (subhead) loadTl.fromTo(subhead, { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6 }, 0.5);
    if (cta) loadTl.fromTo(cta, { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6 }, 0.6);
    if (trust) loadTl.fromTo(trust, { y: 14, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5 }, 0.68);

    const handleMouseMove = (e: MouseEvent) => {
      if (!parallaxEnabled || !xTo || !yTo || window.innerWidth < 1024) return;
      const rect = section.getBoundingClientRect();
      const nx = (e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
      const ny = (e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2);
      xTo(nx * 8);
      yTo(ny * 5);
    };

    const handleMouseLeave = () => {
      if (!slider) return;
      gsap.to(slider, { x: 0, y: 0, duration: 0.8, ease: 'power3.out' });
    };

    section.addEventListener('mousemove', handleMouseMove);
    section.addEventListener('mouseleave', handleMouseLeave);
  }
</script>
