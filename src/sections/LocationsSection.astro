---
import LocationMap from '../components/LocationMap.svelte';
---

<section
  id="locations"
  class="bg-yeg-bg py-20 lg:py-28 relative overflow-hidden"
  style="border-top: 1px solid rgba(0,0,0,0.06);"
>
  <!-- Background word -->
  <span
    class="bg-word absolute top-1/2 right-[-4vw] -translate-y-1/2 select-none pointer-events-none"
    aria-hidden="true"
  >REGION</span>

  <div class="px-6 lg:px-[8vw] relative z-10">
    <!-- Header -->
    <div data-locations-header class="mb-10 lg:mb-14">
      <p class="text-xs font-medium text-yeg-amber/60 uppercase tracking-widest mb-3">
        Service Area
      </p>
      <h2 class="font-display font-extrabold text-display-lg text-yeg-text mb-4">
        We Come to You — Across the<br class="hidden lg:block" /> Greater Edmonton Region
      </h2>
      <p class="text-yeg-text-secondary text-lg max-w-2xl">
        From Edmonton's core to communities two hours out, our certified team deploys anywhere in Alberta.
      </p>
    </div>

    <!-- Interactive map + pills island -->
    <LocationMap client:visible />

    <!-- Footer note -->
    <p data-locations-footer class="text-sm text-yeg-text-secondary mt-8">
      Outside this list? We still respond —{' '}
      <a href="tel:+17804793285" class="text-yeg-amber hover:underline font-medium">
        call us
      </a>{' '}
      and we'll get there.
    </p>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('#locations');
  if (section) {
    const header = section.querySelector('[data-locations-header]');
    const footer = section.querySelector('[data-locations-footer]');

    if (header) {
      gsap.set(header, { y: 24, opacity: 0 });
      gsap.to(header, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: { trigger: section, start: 'top 80%', once: true },
      });
    }

    if (footer) {
      gsap.set(footer, { opacity: 0 });
      gsap.to(footer, {
        opacity: 1,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: footer, start: 'top 92%', once: true },
      });
    }
  }
</script>
