# Copy the values you need into .env.local (never commit real values).

# --- Lead backend ---
DATABASE_URL=            # Neon Postgres connection string
ADMIN_PASSWORD=          # /admin panel password
RESEND_API_KEY=          # transactional email

# --- GA4 + Google Ads tracking (optional — site ships with tracking dormant) ---
# Setup guide: docs/google-ads-tracking-setup.md
PUBLIC_GA4_ID=           # G-XXXXXXXXXX  (GA4 Measurement ID)
PUBLIC_AW_ID=            # AW-XXXXXXXXXX (Google Ads conversion ID)
PUBLIC_AW_CALL_LABEL=    # call conversion label (string after AW-XXXX/)
PUBLIC_AW_FORM_LABEL=    # form conversion label
